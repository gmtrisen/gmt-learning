# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file or real keys to GitHub.

# Get these from your IntaSend dashboard: Settings -> API Keys & Webhooks
INTASEND_PUBLISHABLE_KEY=ISPubKey_test_xxxxxxxxxxxxxxxxxxxxx
INTASEND_SECRET_KEY=ISSecretKey_test_xxxxxxxxxxxxxxxxxxxxx

# "true" while testing with IntaSend sandbox, "false" once you go live with real payments
INTASEND_TEST_MODE=true

# Password to log into /admin — pick something only you know, not the example below.
ADMIN_PASSWORD=change-this-to-a-real-password

# Random string used to sign admin login sessions. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-a-generated-random-string

# Local testing: leave as-is (creates a local SQLite file).
# On Render: this gets set automatically if you attach a Postgres database.
DATABASE_URL=sqlite:///gmt_learning.db

# Where uploaded resource PDFs are stored on disk (not web-accessible directly)
UPLOAD_DIR=./protected_files
